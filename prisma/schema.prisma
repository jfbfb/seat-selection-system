// =============================================================================
// 数据模型（Prisma Schema）
// -----------------------------------------------------------------------------
// 这是整个项目的「地基」。建议学习时从这里开始，弄清表与表之间的关系。
//
// 角色划分：
//   Admin   → 系统管理员，负责创建老师账号
//   Teacher → 老师，管理自己的班级
//   学生    → 不建账号，凭 InviteCode 选座，凭 viewToken 查看
//
// 核心业务链：
//   Class（班级）→ Seat（座位格子）→ Selection（某学生占了某座）
//   InviteCode（邀请码）与 Selection 一对一，保证一码一座
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 管理员表：通常只有 1 个，由 seed 脚本初始化
model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admins")
}

// 老师表：登录后管理多个 Class
model Teacher {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  classes      Class[]

  @@map("teachers")
}

// 班级表：包含行列数、讲台位置、选座是否开放
model Class {
  id            String       @id @default(uuid())
  teacherId     String       @map("teacher_id")
  name          String
  description   String?
  rows          Int
  cols          Int
  podiumCol     Int          @default(1) @map("podium_col")
  podiumSpan    Int          @default(2) @map("podium_span")
  selectionOpen Boolean      @default(true) @map("selection_open")
  createdAt     DateTime     @default(now()) @map("created_at")
  teacher       Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  seats         Seat[]
  inviteCodes   InviteCode[]
  selections    Selection[]

  @@map("classes")
}

enum SeatType {
  normal
  aisle
  empty
}

// 座位格子：normal=可选座，aisle=过道，empty=空位（不参与选座）
model Seat {
  id        String      @id @default(uuid())
  classId   String      @map("class_id")
  row       Int
  col       Int
  type      SeatType    @default(normal)
  class     Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  selection Selection?

  @@unique([classId, row, col])
  @@map("seats")
}

enum InviteCodeStatus {
  unused
  used
}

// 邀请码：老师逐个生成，学生凭链接 /select/{code} 进入
model InviteCode {
  id         String           @id @default(uuid())
  classId    String           @map("class_id")
  code       String           @unique
  status     InviteCodeStatus @default(unused)
  usedAt     DateTime?        @map("used_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  class      Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  selection  Selection?

  @@map("invite_codes")
}

enum Gender {
  male
  female
  other
}

// 选座记录：连接 学生-座位-邀请码；viewToken 用于免登录查看
model Selection {
  id           String     @id @default(uuid())
  classId      String     @map("class_id")
  seatId       String     @unique @map("seat_id")
  inviteCodeId String     @unique @map("invite_code_id")
  studentName  String     @map("student_name")
  gender       Gender
  viewToken    String     @unique @map("view_token")
  createdAt    DateTime   @default(now()) @map("created_at")
  class        Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  seat         Seat       @relation(fields: [seatId], references: [id])
  inviteCode   InviteCode @relation(fields: [inviteCodeId], references: [id])

  @@map("selections")
}
